{
  "schemaVersion": 1,
  "id": "colonycraft",
  "version": "${version}",
  "name": "ColonyCraft",
  "description": "Colony Survival mechanics in Minecraft! Place a Colony Banner, recruit Colonists, assign them jobs, collect resources automatically and defend your colony from nightly monster waves. Features 25+ jobs, quest system, decorative Chisel tool, wave warnings, and much more.",
  "authors": [
    "Wux"
  ],
  "contact": {
    "homepage": "https://github.com/WuxCZ/colonycraft",
    "sources": "https://github.com/WuxCZ/colonycraft",
    "issues": "https://github.com/WuxCZ/colonycraft/issues"
  },
  "license": "MIT",
  "icon": "assets/colonycraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cz.wux.colonycraft.ColonyCraftMod"
    ],
    "client": [
      "cz.wux.colonycraft.client.ColonyCraftClient"
    ]
  },
  "mixins": [
    "colonycraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.0",
    "fabric-api": "*",
    "minecraft": "~1.21.11",
    "java": ">=21"
  },
  "suggests": {
    "entity_model_features": "*",
    "entity_texture_features": "*"
  }
}
